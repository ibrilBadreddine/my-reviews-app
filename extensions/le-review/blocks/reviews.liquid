{% render 'asset.app' %}
{% render 'asset.button' %}
{% render 'asset.carousel' %}
{% render 'asset.modal' %}

<link rel="stylesheet" href="https://cdn.hugeicons.com/font/hgi-stroke-rounded.css">

{% if block.settings.widget_layout == 'carousel' %}
  {% case block.settings.widget_carousel_type %}
    {% when 'dynamic' %}
      {% render 'widget.dynamic' %}
    {% when 'video-slider' %}
      {% render 'widget.video' %}
    {% when 'testimonials' %}
      {% render 'widget.testimonials' %}
  {% endcase %}
{% else %}
  {% case block.settings.widget_floating_type %}
    {% when 'pop-up' %}
      {% render 'widget.pop-up' %}
    {% when 'sidebar' %}
      {% render 'widget.sidebar' %}
  {% endcase %}
{% endif %}

{% schema %}
{
  "label": "t:blocks.reviews.label",
  "target": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:blocks.reviews.settings.widget.label"
    },
    {
      "type": "select",
      "id": "widget_layout",
      "label": "t:blocks.reviews.settings.widget.layout.label",
      "options": [
        {
          "label": "t:blocks.reviews.settings.widget.layout.options.carousel",
          "value": "carousel"
        },
        {
          "label": "t:blocks.reviews.settings.widget.layout.options.floating",
          "value": "floating"
        }
      ],
      "default": "carousel"
    },
    {
      "type": "select",
      "id": "widget_carousel_type",
      "label": "t:blocks.reviews.settings.widget.type.label",
