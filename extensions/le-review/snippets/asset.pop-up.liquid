{% comment %}
  Renders "pop-up widget" CSS styles

  Usage:
  {% render 'asset.pop-up' %}
{% endcomment %}

{% case block.settings.corner_radius %}
  {% when 'flat' %}
    {% assign media_radius = '0px' %}
    {% assign content_radius = '0px' %}
  {% when 'soft' %}
    {% assign media_radius = 'calc(1px * infinity)' %}
    {% assign content_radius = '8px' %}
  {% when 'softer' %}
    {% assign media_radius = 'calc(1px * infinity)' %}
    {% assign content_radius = '12px' %}
{% endcase %}

{% style %}
  [ui-widget='pop-up'][popover] {
    --pop-up-width: 400px;

    display: flex;
    visibility: hidden;
    position: fixed;
    width: 400px;
    width: var(--pop-up-width);
    padding: var(--spacing-24);
    transform: translateX(calc(400px * -1));
    transform: translateX(calc(var(--pop-up-width) * -1));
    transition: var(--transition-expressive-slow-spatial);
    border: none;
    opacity: 0;
    background-color: transparent !important;
    inset: unset;
    inset-block-end: var(--spacing-0);
    inset-inline-start: var(--spacing-0);
    filter: blur(2px);
    z-index: 50;
  }

  [ui-widget='pop-up'][popover]:popover-open {
    visibility: visible;
    transform: translateX(0);
    opacity: 1;
    filter: blur(0);
  }

  @starting-style {
    [ui-widget='pop-up'][popover]:popover-open {
      visibility: hidden;
      transform: translateX(calc(var(--pop-up-width) * -1));
      opacity: 0;
      filter: blur(2px);
    }
  }

  [ui-widget='pop-up'][popover] .pop-up-card {
    display: flex;
    flex: 1;
    align-items: flex-start;
    gap: var(--spacing-8);
    cursor: zoom-in;
  }

  [ui-widget='pop-up'][popover] .pop-up-card .media {
    width: 68px;
    height: auto;
    overflow: hidden;
    border-radius: {{ media_radius }};
    border-inline-end-color: transparent;
    aspect-ratio: 1/1;
  }

  [ui-widget='pop-up'][popover] .pop-up-card .media > img {
    -o-object-fit: cover;
    object-fit: cover;
  }

  [ui-widget='pop-up'][popover] .pop-up-card .content {
    display: flex;
    position: relative;
    flex: 1;
    flex-direction: column;
    padding: var(--spacing-16);
    border-radius: {{ content_radius }};
    background-color: var(--color-on-primary);
    box-shadow: 0 4px 24px rgba(0, 0, 0, 0.1);
    gap: var(--spacing-4);
  }

  [ui-widget='pop-up'][popover] .pop-up-card .content .info {
    display: flex;
    gap: var(--spacing-8);
  }

  [ui-widget='pop-up'][popover] .pop-up-card .content .info .author {
    font: var(--font-title-sm);
  }

  [ui-widget='pop-up'][popover] .pop-up-card .content .info .stars {
    display: flex;
    align-items: center;
    gap: var(--spacing-4);
  }

  [ui-widget='pop-up'][popover] .pop-up-card .content .detail {
    display: -webkit-box;
    overflow: hidden;
    color: var(--color-on-surface-variant);
    font: var(--font-body-sm);
    text-align: start;
    word-break: break-all;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
    line-clamp: 2;
  }

  [ui-widget='pop-up'][popover] .close {
    position: absolute;
    inset-block-start: var(--spacing-32);
    inset-inline-end: var(--spacing-32);
  }

  @media (max-width: 769px) {
    [ui-widget='pop-up'][popover] {
      --pop-up-width: 100%;
    }
  }
{% endstyle %}
