{% comment %}
  Renders modal component CSS styles

  Usage:
  {% render 'asset.modal' %}
{% endcomment %}

{% case block.settings.corner_radius %}
  {% when 'flat' %}
    {% assign modal_radius = '0px' %}
  {% when 'soft' %}
    {% assign modal_radius = '12px' %}
  {% when 'softer' %}
    {% assign modal_radius = '20px' %}
{% endcase %}

{% style %}
  /*
    Component: Modal

    Usage:
      - <button popovertarget="my-modal">  Click to Open </button>

        <div ui-slot="modal-content" id="my-modal" popover> My Modal Content </div>

  */

  /* Content */
  [ui-slot='modal-content'][popover] {
    display: flex;
    visibility: hidden;
    inset: auto;
    left: 50%;
    flex-direction: column;
    width: 100%;
    max-width: 402px;
    transition: var(--transition-expressive-fast-spatial);
    border: none;
    opacity: 0;
    background-color: var(--modal-background);
    color: inherit;
    filter: blur(2px);

    /* Header */
    [ui-slot='modal-header'] {
      display: flex;
      position: sticky;
      z-index: 2;
      align-items: center;
      justify-content: space-between;
      padding: var(--spacing-24);
      background-color: var(--modal-background);
      gap: var(--spacing-12);
      inset-block-start: var(--spacing-0);

      /* Title */
      [ui-slot='modal-title'] {
        font: var(--font-title-md);
      }
    }

    /* Body */
    [ui-slot='modal-body'] {
      padding-inline: var(--spacing-24);
    }

    /* Body */
    [ui-slot='modal-footer'] {
      display: grid;
      gap: var(--spacing-12);
      grid-template-columns: repeat(2, 1fr);
      padding: var(--spacing-24);
    }

    /* Backdrop */
    &::backdrop {
      transition: var(--transition-standard-default-spatial);
    }

    /* State */
    &:popover-open {
      visibility: visible;
      opacity: 1;
      filter: blur(0);

      &::backdrop {
        backdrop-filter: blur(10px);
        background-color: color-mix(in srgb, currentcolor 15%, transparent);
      }

      @starting-style {
        visibility: hidden;
        opacity: 0;
        filter: blur(2px);

        &::backdrop {
          backdrop-filter: blur(0);
          background-color: transparent;
        }
      }
    }

    @media (width > 769px) {
      transform: translate(-50%, -50%) scale(0.94);
      border-radius: {{ modal_radius }};
      inset-block-start: 50%;

      &:popover-open {
        transform: translate(-50%, -50%) scale(1);

        @starting-style {
          transform: translate(-50%, -50%) scale(0.94);
        }
      }
    }

    @media (width <= 769px) {
      width: 100%;
      height: 100%;
      inset: 0;
    }

    &[data-intensity='as-solid-bg'],
    &[data-intensity='as-foreground'] {
      --modal-background: var(--color-on-primary);
    }

    &[data-intensity='as-light-bg'] {
      --modal-background: var(--color-primary-container);
    }
  }
{% endstyle %}
