{% comment %}
  Renders "sidebar widget" CSS styles

  Usage:
  {% render 'asset.sidebar' %}
{% endcomment %}

{% case block.settings.corner_radius %}
  {% when 'flat' %}
    {% assign media_radius = '0px' %}
    {% assign image_radius = '0px' %}
    {% assign trigger_radius = '0px' %}
  {% when 'soft' %}
    {% assign media_radius = '8px' %}
    {% assign image_radius = '6px' %}
    {% assign trigger_radius = '12px' %}
  {% when 'softer' %}
    {% assign media_radius = '12px' %}
    {% assign image_radius = '8px' %}
    {% assign trigger_radius = '20px' %}
{% endcase %}

{% style %}
  [ui-widget='sidebar'] {
    display: flex;
    position: fixed;
    z-index: 50;
    align-items: center;
    justify-content: center;
    color: var(--color-on-primary) !important;
    background-color: var(--color-primary) !important;
    inset-block-start: 25%;
    border-radius: 0;
    border-start-start-radius: {{ trigger_radius }};
    border-start-end-radius: {{ trigger_radius }};
  }

  [ui-widget='sidebar'][data-position='left'] {
    inset-inline-start: 0;
    transform: translateY(-50%) rotate(90deg);
    transform-origin: bottom left;

    &:dir(rtl) {
      transform: translateY(-50%) rotate(-90deg);
      transform-origin: bottom right;
    }
  }

  [ui-widget='sidebar'][data-position='right'] {
    inset-inline-end: 0;
    transform: translateY(-50%) rotate(-90deg);
    transform-origin: bottom right;

    &:dir(rtl) {
      transform: translateY(-50%) rotate(90deg);
      transform-origin: bottom left;
    }
  }

  [ui-widget='sidebar'] span {
    display: flex;
    align-items: center;
    padding: var(--spacing-12) var(--spacing-24);
    font: var(--font-body-lg);
    gap: var(--spacing-8);
    white-space: nowrap;
  }

  [ui-component='reviews'][popover] {
    display: flex;
    flex-direction: column;
    color: var(--color-primary);
  }

  [ui-component='reviews'][popover] [ui-slot='modal-body'] {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    padding-block-end: var(--spacing-24);
    grid-gap: var(--spacing-12);
    gap: var(--spacing-12);
  }

  [ui-component='reviews'][popover] [ui-slot='modal-body'] .review-card {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    width: 100%;
    height: 100%;
    color: var(--color-primary);
    background-color: transparent;
    cursor: zoom-in;
    gap: var(--spacing-16);
  }

  [ui-component='reviews'][popover] [ui-slot='modal-body'] .review-card .media {
    width: 100%;
    height: auto;
    aspect-ratio: 1/1;
    overflow: hidden;
    border-radius: {{ media_radius }};
  }

  [ui-component='reviews'][popover] [ui-slot='modal-body'] .review-card .media > img {
    -o-object-fit: cover;
    object-fit: cover;
  }

  [ui-component='reviews'][popover] [ui-slot='modal-body'] .review-card .content {
    display: flex;
    flex: 1;
    flex-direction: column;
    justify-content: space-between;
    text-align: start;
    gap: var(--spacing-16);
  }

  [ui-component='reviews'][popover] [ui-slot='modal-body'] .review-card .content .info {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-4);
  }

  [ui-component='reviews'][popover] [ui-slot='modal-body'] .review-card .content .info .author {
    font: var(--font-body-lg);
  }

  [ui-component='reviews'][popover] [ui-slot='modal-body'] .review-card .content .info .detail {
    display: -webkit-box;
    margin-block-start: var(--spacing-8);
    overflow: hidden;
    text-overflow: ellipsis;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 3;
  }

  [ui-component='reviews'][popover] [ui-slot='modal-body'] .review-card .content .product {
    display: flex;
    align-items: center;
    gap: var(--spacing-12);
    padding-block-start: var(--spacing-16);
    border-block-start: 1px solid var(--color-surface-variant);
  }

  [ui-component='reviews'][popover] [ui-slot='modal-body'] .review-card .content .product .image {
    width: 50px;
    height: auto;
    aspect-ratio: 1/1;
    overflow: hidden;
    border-radius: {{ image_radius }};
  }

  [ui-component='reviews'][popover] [ui-slot='modal-body'] .review-card .content .product .image > img {
    -o-object-fit: cover;
    object-fit: cover;
  }

  [ui-component='reviews'][popover] [ui-slot='modal-body'] .review-card .content .product .bio {
    display: grid;
    grid-gap: var(--spacing-12);
    gap: var(--spacing-12);
  }

  [ui-component='reviews'][popover] [ui-slot='modal-body'] .review-card .content .product .bio .name {
    font: var(--font-body-md);
  }

  @media (max-width: 1280px) {
    [ui-component='reviews'][popover] [ui-slot='modal-body'] {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 1024px) {
    [ui-component='reviews'][popover] [ui-slot='modal-body'] {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (min-width: 769.02px) {
    [ui-component='reviews'][popover] {
      min-width: 80%;
      height: 80vh;
    }
  }

  @media (max-width: 769px) {
    [ui-component='reviews'][popover] {
      min-width: 100%;
    }
    [ui-component='reviews'][popover] [ui-slot='modal-body'] {
      grid-template-columns: repeat(2, 1fr);
    }
  }
{% endstyle %}
